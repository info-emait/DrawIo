{
    "manifestVersion": 1,
    "id": "#{Id}#",
    "version": "#{Version}#",
    "name": "Draw.io",
    "description": "#{Description}#",
    "publisher": "#{Publisher}#",
    "public": true,
    "categories": [
        "Azure Boards"
    ], 
    "targets": [{
        "id": "Microsoft.VisualStudio.Services"
    }],
    "icons": {
        "default": "img/logo.png"
    },
    "screenshots": [{
        "path": "img/screenshot1.png"
    }, {
        "path": "img/screenshot2.png"
    }, {
        "path": "img/screenshot3.png"
    }, {
        "path": "img/screenshot4.png"
    }],
    "tags": [
        "draw", "drawio", "diagrams", "uml", "flowchart", "classdiagram"
    ],
    "links": {
        "support": {
            "uri": "mailto:info.emait@gmail.com"
        }
    },
    "repository": {
        "type": "git",
        "uri": "https://github.com/info-emait/DrawIo"
    },
    "content": {
        "details": {
            "path": "Overview.md"
        },
        "license": {
            "path": "License.md"
        }
    },
    "branding": {
        "color": "#212121",
        "theme": "dark"
    },
    "contributions": [{
        "id": "#{Id}#-feature",
        "type": "ms.vss-web.feature",
        "targets": [
            "ms.vss-web.managed-features-onprem"
        ],
        "description": "Draw.io feature adds the new Draw.io hub to the Overview group.",
        "properties": {
            "name": "Draw.io",
            "userConfigurable": true,
            "hostConfigurable": true,
            "defaultState": true,
            "hostScopes": [
                "project", null
            ]
        }
    }, {
        "id": "#{Id}#-hub",
        "type": "ms.vss-web.tab",
        "targets": [
            "ms.vss-work-web.query-tabs"
        ],
        "properties": {
            "uri": "hub.html?v=#{Version}#",
            "title": "Draw.io hub",
            "name": "Draw.io"
        },
        "constraints": [{
            "name": "Feature",
            "properties": {
                "featureId": "#{Publisher}#.#{Id}#.#{Id}#-feature"
            }
        }]
    }],
    "files": [
        { "path": "hub.html", "addressable": true },
        { "path": "assets", "addressable": true },
        { "path": "img", "addressable": true }
    ],
    "scopes":[
        "vso.work",
        "vso.work_write",
        "vso.code_write",
        "vso.code_status"
    ]
}
