{
    "name": "drawio",
    "description": "This extension brings draw.io directly into Azure DevOps, so you can view, create and edit your diagrams.",
    "version": "0.0.360",
    "author": "emait",
    "private": true,
    "type": "module",
    "icon": "https://martinsutka.github.io/icongenerator/#",
    "repository": {
        "type": "git",
        "url": "https://github.com/info-emait/DrawIo"
    },
    "scripts": {
        "dev": "vite",
        "prebuild": "npm version patch --no-git-tag-version",
        "build": "vite build && node scripts/generateExtensionManifest.js",
        "predebug": "npm version patch --no-git-tag-version",
        "debug": "vite build --mode debug && node scripts/generateExtensionManifest.js",
        "preview": "vite preview",
        "package": "tfx extension create --root dist --manifest-globs vss-extension.json --output-path dist && node scripts/cleanupDist.js"
    },
    "devDependencies": {
        "esbuild": "^0.28.0",
        "sass": "1.99.0",
        "tfx-cli": "0.23.1",
        "vite": "8.0.11"
    },
    "dependencies": {
        "azure-devops-extension-api": "5.271.0",
        "azure-devops-extension-sdk": "4.2.0",
        "azure-devops-ui": "2.272.0",
        "knockout": "^3.5.1"
    }
}
